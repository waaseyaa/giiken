{
    "name": "waaseyaa/giiken",
    "description": "Giiken — Sovereign Indigenous knowledge management platform",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.4",
        "nesbot/carbon": "^3.0",
        "symfony/dotenv": "^7.4",
        "symfony/yaml": "^7.4",
        "waaseyaa/access": "^0.1.0-alpha.136",
        "waaseyaa/admin-surface": "^0.1.0-alpha.136",
        "waaseyaa/ai-agent": "^0.1.0-alpha.136",
        "waaseyaa/ai-pipeline": "^0.1.0-alpha.136",
        "waaseyaa/ai-schema": "^0.1.0-alpha.136",
        "waaseyaa/ai-vector": "^0.1.0-alpha.136",
        "waaseyaa/api": "^0.1.0-alpha.136",
        "waaseyaa/auth": "^0.1.0-alpha.136",
        "waaseyaa/cache": "^0.1.0-alpha.136",
        "waaseyaa/cli": "^0.1.0-alpha.136",
        "waaseyaa/config": "^0.1.0-alpha.136",
        "waaseyaa/core": "^0.1.0-alpha.136",
        "waaseyaa/database-legacy": "^0.1.0-alpha.136",
        "waaseyaa/entity": "^0.1.0-alpha.136",
        "waaseyaa/entity-storage": "^0.1.0-alpha.136",
        "waaseyaa/field": "^0.1.0-alpha.136",
        "waaseyaa/foundation": "^0.1.0-alpha.136",
        "waaseyaa/i18n": "^0.1.0-alpha.136",
        "waaseyaa/inertia": "^0.1.0-alpha.136",
        "waaseyaa/ingestion": "^0.1.0-alpha.136",
        "waaseyaa/media": "^0.1.0-alpha.136",
        "waaseyaa/plugin": "^0.1.0-alpha.136",
        "waaseyaa/queue": "^0.1.0-alpha.136",
        "waaseyaa/routing": "^0.1.0-alpha.136",
        "waaseyaa/search": "^0.1.0-alpha.136",
        "waaseyaa/ssr": "^0.1.0-alpha.136",
        "waaseyaa/state": "^0.1.0-alpha.136",
        "waaseyaa/taxonomy": "^0.1.0-alpha.136",
        "waaseyaa/testing": "^0.1.0-alpha.136",
        "waaseyaa/typed-data": "^0.1.0-alpha.136",
        "waaseyaa/user": "^0.1.0-alpha.136",
        "waaseyaa/validation": "^0.1.0-alpha.136",
        "waaseyaa/workflows": "^0.1.0-alpha.136"
    },
    "repositories": [
        { "type": "vcs", "url": "https://github.com/waaseyaa/access.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/admin-surface.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/ai-agent.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/ai-pipeline.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/ai-schema.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/ai-vector.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/api.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/auth.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/cache.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/cli.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/config.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/core.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/database-legacy.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/entity.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/entity-storage.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/field.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/foundation.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/i18n.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/inertia.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/ingestion.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/media.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/plugin.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/queue.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/routing.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/search.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/ssr.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/state.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/taxonomy.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/testing.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/typed-data.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/user.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/validation.git" },
        { "type": "vcs", "url": "https://github.com/waaseyaa/workflows.git" }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "wikimedia/composer-merge-plugin": true
        },
        "optimize-autoloader": true,
        "process-timeout": 0,
        "sort-packages": true
    },
    "scripts": {
        "analyse": "./vendor/bin/phpstan analyse src tests --level=8 --no-progress",
        "dev": "php bin/waaseyaa serve",
        "test": "./vendor/bin/phpunit",
        "post-install-cmd": [
            "@php scripts/repoint-vendor-bin.php"
        ],
        "post-update-cmd": [
            "@php scripts/repoint-vendor-bin.php"
        ]
    },
    "extra": {
        "merge-plugin": {
            "include": [
                "composer.local.json"
            ],
            "prepend-repositories": true
        },
        "waaseyaa": {
            "providers": [
                "App\\Provider\\AppServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10.5",
        "wikimedia/composer-merge-plugin": "^2.1"
    }
}
