{
    "name": "waaseyaa/giiken",
    "description": "Giiken — Sovereign Indigenous knowledge management platform",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.4",
        "nesbot/carbon": "^3.0",
        "symfony/dotenv": "^7.4",
        "symfony/yaml": "^7.4",
        "waaseyaa/access": "^0.1",
        "waaseyaa/admin-surface": "^0.1",
        "waaseyaa/ai-agent": "^0.1",
        "waaseyaa/ai-pipeline": "^0.1",
        "waaseyaa/ai-schema": "^0.1",
        "waaseyaa/ai-vector": "^0.1",
        "waaseyaa/api": "^0.1",
        "waaseyaa/auth": "^0.1",
        "waaseyaa/cache": "^0.1",
        "waaseyaa/cli": "^0.1",
        "waaseyaa/config": "^0.1",
        "waaseyaa/core": "^0.1",
        "waaseyaa/database-legacy": "^0.1",
        "waaseyaa/entity": "^0.1",
        "waaseyaa/entity-storage": "^0.1",
        "waaseyaa/field": "^0.1",
        "waaseyaa/foundation": "^0.1",
        "waaseyaa/i18n": "^0.1",
        "waaseyaa/inertia": "^0.1",
        "waaseyaa/ingestion": "^0.1",
        "waaseyaa/media": "^0.1",
        "waaseyaa/plugin": "^0.1",
        "waaseyaa/queue": "^0.1",
        "waaseyaa/routing": "^0.1",
        "waaseyaa/search": "^0.1",
        "waaseyaa/ssr": "^0.1",
        "waaseyaa/state": "^0.1",
        "waaseyaa/taxonomy": "^0.1",
        "waaseyaa/testing": "^0.1",
        "waaseyaa/typed-data": "^0.1",
        "waaseyaa/user": "^0.1",
        "waaseyaa/validation": "^0.1",
        "waaseyaa/workflows": "^0.1"
    },
    "autoload": {
        "psr-4": {
            "Giiken\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "analyse": "./vendor/bin/phpstan analyse src tests --level=8 --no-progress",
        "dev": "php bin/waaseyaa serve",
        "test": "./vendor/bin/phpunit"
    },
    "extra": {
        "waaseyaa": {
            "providers": [
                "Giiken\\GiikenServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10"
    }
}
