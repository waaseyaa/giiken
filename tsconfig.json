{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "noEmit": true,
    "esModuleInterop": true,
    "paths": { "@/*": ["./resources/js/*"] },
    "types": ["vite/client", "vitest/globals"]
  },
  "include": [
    "resources/js/**/*.ts",
    "resources/js/**/*.vue",
    "tests/js/**/*.ts"
  ]
}
